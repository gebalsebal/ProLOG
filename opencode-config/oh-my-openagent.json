{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-openagent/dev/assets/oh-my-opencode.schema.json",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "hephaestus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "oracle": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "librarian": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "explore": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "multimodal-looker": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium",
      "fallback_models": [
        {
          "model": "openai/gpt-5-nano"
        }
      ]
    },
    "prometheus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "metis": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "atlas": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    }
  },
  "categories": {
    "visual-engineering": {
      "model": "openai/gpt-5.5-fast",
      "variant": "high"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "deep": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "artistry": {
      "model": "openai/gpt-5.5-fast",
      "variant": "xhigh"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini-fast"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    },
    "writing": {
      "model": "openai/gpt-5.5-fast",
      "variant": "medium"
    }
  },
  "team_mode": {
    "enabled": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "tmux_visualization": true
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
}
